# ============================================
# CONFIGURATION DEVIS ARTISANT
# Copier ce fichier en .env et remplir les valeurs
# ============================================

# Serveur
PORT=3000
NODE_ENV=development

# ============================================
# IA - Anthropic Claude
# ============================================
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ============================================
# GOOGLE MAPS API
# ============================================
GOOGLE_MAPS_API_KEY=your-google-maps-key-here

# ============================================
# EMAIL (SMTP)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre@email.com
SMTP_PASS=votre-mot-de-passe-app
EMAIL_FROM=votre@email.com

# ============================================
# ONEDRIVE (optionnel)
# ============================================
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=
ONEDRIVE_TENANT_ID=

# ============================================
# INFORMATIONS ENTREPRISE (défaut)
# ============================================
COMPANY_NAME=Mon Entreprise
COMPANY_ADDRESS=1 Rue de la Paix, 75001 Paris
COMPANY_SIRET=12345678901234
COMPANY_PHONE=01 23 45 67 89
COMPANY_EMAIL=contact@monentreprise.fr
COMPANY_DEPOT_ADDRESS=1 Rue de la Paix, 75001 Paris

# ============================================
# PARAMÈTRES CHIFFRAGE
# ============================================
DEFAULT_MARGIN_MATERIAL=30
DEFAULT_HOURLY_RATE=15
DEFAULT_KM_RATE=0.30
DEFAULT_TVA=10
